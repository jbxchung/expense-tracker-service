// application user
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  role          UserRole
  passwordHash  String?   // nullable for now until existing users all have a password set
  accounts      Account[]
  categories    Category[]
  importers     Importer[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum UserRole {
  OWNER
  USER
}

// from session middleware, just keeping prisma schema in sync
model UserSession {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire])
  @@map("user_sessions")
}